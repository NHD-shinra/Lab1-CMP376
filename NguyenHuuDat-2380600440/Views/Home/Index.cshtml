@model IEnumerable<NguyenHuuDat_2380600440.Models.Product>

@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Thế Giới Công Nghệ Đỉnh Cao";
}

<!-- ==================== HERO SECTION (DYNAMIC GRAPHICS) ==================== -->
<section class="hero-section">
    <!-- Ambient Background Blobs -->
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>
    <div class="bg-blob blob-3"></div>

    <div class="hero-container">
        <!-- Hero Text Details -->
        <div class="hero-content">
            <div class="hero-tag">
                <i class="fa-solid fa-fire-flame-curved"></i> Xu Hướng Công Nghệ 2026
            </div>
            <h1 class="hero-title">
                Kỷ Nguyên Công Nghệ<br>
                <span class="gradient-text">Kiến Tạo Tương Lai</span>
            </h1>
            <p class="hero-description">
                Khám phá bộ sưu tập thiết bị cao cấp dẫn đầu xu thế. Nâng tầm trải nghiệm làm việc và giải trí của bạn với những kiệt tác công nghệ được tinh tuyển xuất sắc nhất.
            </p>
            <div class="hero-actions">
                <a href="#productsSection" class="btn-cta">
                    Mua Ngay <i class="fa-solid fa-arrow-right"></i>
                </a>
                <a href="#productsSection" class="btn-secondary">
                    Tìm hiểu thêm <i class="fa-solid fa-chevron-down"></i>
                </a>
            </div>
        </div>

        <!-- Hero Visuals (Glass Cards) -->
        <div class="hero-visual">
            <div class="hero-main-card">
                <div class="hero-card-brand">NHD PLATINUM</div>
                <div class="hero-card-display">
                    FUTURE<br>
                    IS NOW
                </div>
                <div class="hero-card-bottom">
                    <div class="hero-chip" title="Secure Payment Chip"></div>
                    <div style="text-align: right;">
                        <span style="font-size: 0.6rem; color: var(--text-muted); display: block; letter-spacing: 0.1em;">CARDHOLDER</span>
                        <span style="font-family: var(--font-heading); font-size: 0.8rem; font-weight: 700; color: white;">NGUYEN HUU DAT</span>
                    </div>
                </div>
            </div>

            <!-- Floating glass elements -->
            <div class="floating-glass-chip chip-1">
                <div class="chip-icon">
                    <i class="fa-solid fa-star"></i>
                </div>
                <div class="chip-text">
                    <h4>4.9 / 5.0 Rating</h4>
                    <p>Hơn 15,000+ đánh giá</p>
                </div>
            </div>

            <div class="floating-glass-chip chip-2">
                <div class="chip-icon" style="background: rgba(16, 185, 129, 0.2); color: var(--accent);">
                    <i class="fa-solid fa-truck-fast"></i>
                </div>
                <div class="chip-text">
                    <h4>Miễn phí vận chuyển</h4>
                    <p>Cho hóa đơn từ 5tr</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ==================== PRODUCTS SECTION (GRID & CARDS) ==================== -->
<section class="products-section" id="productsSection">
    <div class="section-header">
        <span class="section-tag">Bộ Sưu Tập Đỉnh Cao</span>
        <h2 class="section-title">Sản Phẩm Công Nghệ Nổi Bật</h2>
    </div>

    <!-- Product Grid -->
    <div class="products-grid">
        @if (Model != null && Model.Any())
        {
            int counter = 0;
            foreach (var item in Model)
            {
                counter++;
                // Create diverse mock discount tags
                string saleText = "Hot Item";
                if (counter % 3 == 0) saleText = "-10% OFF";
                else if (counter % 5 == 0) saleText = "New Arrival";
                else if (counter % 2 == 0) saleText = "Bestseller";

                <div class="product-card">
                    <!-- Image Wrapper -->
                    <div class="product-image-wrapper">
                        <span class="sale-tag">@saleText</span>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Name" class="product-image" loading="lazy" />
                        }
                        else
                        {
                            <img src="https://images.unsplash.com/photo-1531297484001-80022131f5a1?w=500" alt="@item.Name" class="product-image" loading="lazy" />
                        }
                    </div>

                    <!-- Meta Data -->
                    <div class="product-meta">
                        <span class="product-category">
                            @(item.CategoryId == 1 ? "Laptop" : item.CategoryId == 2 ? "Smartphone" : "Phụ Kiện")
                        </span>
                        <div class="product-rating">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                    </div>

                    <!-- Title & Desc -->
                    <a href="#" class="product-name">@item.Name</a>
                    <p class="product-description">@item.Description</p>

                    <!-- Price & Buy Button -->
                    <div class="product-footer">
                        <div class="product-price-container">
                            <span class="product-price">@item.Price.ToString("N0") đ</span>
                            @if (counter % 3 == 0 || counter % 2 == 0)
                            {
                                // Simulating original price for discount appearance
                                decimal originalPrice = item.Price * 1.15m;
                                <span class="product-original-price">@originalPrice.ToString("N0") đ</span>
                            }
                        </div>
                        
                        <!-- Add to Cart Trigger (calls JS function) -->
                        <button class="add-to-cart-btn" 
                                onclick="addToCart('@item.Id', `@item.Name`, '@item.Price', '@item.ImageUrl')" 
                                title="Thêm vào giỏ hàng">
                            <i class="fa-solid fa-cart-plus"></i>
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1 / -1; text-align: center; padding: 4rem 0; color: var(--text-muted);">
                <i class="fa-solid fa-circle-exclamation" style="font-size: 2.5rem; margin-bottom: 1rem; color: var(--primary);"></i>
                <p>Hiện tại chưa có sản phẩm nào trong cửa hàng.</p>
                <p style="font-size: 0.9rem;">Vui lòng vào trang quản trị để thêm sản phẩm mới!</p>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        // Smooth scroll for anchors
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth'
                    });
                }
            });
        });

        // Interactive 3D Card Hover Glow effect
        const cards = document.querySelectorAll('.product-card');
        cards.forEach(card => {
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                card.style.setProperty('--mouse-x', `${x}px`);
                card.style.setProperty('--mouse-y', `${y}px`);
            });
        });
    </script>
}
