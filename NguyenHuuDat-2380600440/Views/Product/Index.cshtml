@model IEnumerable<NguyenHuuDat_2380600440.Models.Product>

<h2>Danh sách sản phẩm</h2>
<p><a asp-action="Add" class="btn btn-primary">Thêm sản phẩm mới</a></p>

<table class="table table-bordered align-middle">
    <thead>
        <tr class="table-light">
            <th style="width: 120px;" class="text-center">Hình ảnh</th>
            <th>Tên sản phẩm</th>
            <th>Giá</th>
            <th>Mô tả</th>
            <th style="width: 150px;">Chức năng</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="text-center">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" width="80" height="80" style="object-fit: cover;" class="img-thumbnail" alt="@item.Name" />
                    }
                    else
                    {
                        <span class="text-muted" style="font-size: 0.85rem;">Không có ảnh</span>
                    }
                </td>
                <td><strong>@item.Name</strong></td>
                <td class="text-danger fw-bold">@item.Price.ToString("N0") đ</td>
                <td>@item.Description</td>
                <td>
                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>